{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soundbridge.dev/schema/defs/request-envelope.schema.json",
  "title": "SoundBridge Request Envelope Schema",
  "$ref": "#/$defs/requestEnvelope",
  "$defs": {
    "command": { "$ref": "../protocol.schema.json#/$defs/command" },
    "pluginFormat": { "type": "string", "enum": ["vst3", "au", "lv2", "mock", "unknown"] },
    "requestEnvelope": {
      "type": "object",
      "required": ["type", "id", "command", "payload"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "request" },
        "id": { "type": "string", "minLength": 1 },
        "command": { "$ref": "#/$defs/command" },
        "payload": { "type": "object" },
        "sessionToken": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "command": { "const": "pair" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/pairRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "createInstance" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/createInstanceRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "processAudioBlock" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/processAudioBlockRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "setParameter" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/setParameterRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "setParameterDisplayValue" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/setParameterDisplayValueRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "setPreset" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/setPresetRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "getVst3ProgramData" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/getVst3ProgramDataRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "setVst3ProgramData" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/setVst3ProgramDataRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "setParameterEvents" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/setParameterEventsRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "setParameterCurve" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/setParameterCurveRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "setAutomationLane" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/setAutomationLaneRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "clearAutomationLane" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/clearAutomationLaneRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "getState" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/getStateRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "setState" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/setStateRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "sendMidiEvents" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/sendMidiEventsRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "getLatency" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/getLatencyRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "getTailTime" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/getTailTimeRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "getLayout" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/getLayoutRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "openEditor" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/openEditorRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "closeEditor" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/closeEditorRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "createFileGrant" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/createFileGrantRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "listFileGrants" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "type": "object", "additionalProperties": true }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "revokeFileGrant" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/revokeFileGrantRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "attachFileGrant" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/attachFileGrantRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "listInstanceFileGrants" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/listInstanceFileGrantsRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "detachFileGrant" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/detachFileGrantRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": { "const": "useFileGrant" }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/useFileGrantRequest" }
            }
          }
        }
      ]
    },
    "pairRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "origin": { "type": "string" },
        "pairingToken": { "type": "string" }
      }
    },
    "createInstanceRequest": {
      "type": "object",
      "required": ["pluginId"],
      "additionalProperties": true,
      "properties": {
        "pluginId": { "type": "string", "minLength": 1 },
        "format": { "$ref": "#/$defs/pluginFormat" },
        "sampleRate": { "type": "number", "minimum": 8000, "maximum": 384000 },
        "maxBlockSize": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "inputChannels": { "type": "integer", "minimum": 0, "maximum": 32 },
        "outputChannels": { "type": "integer", "minimum": 1, "maximum": 32 }
      }
    },
    "processAudioBlockRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "blockId": { "type": "number" },
        "timestamp": { "type": "number" },
        "frames": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "sampleRate": { "type": "number", "minimum": 8000, "maximum": 384000 },
        "channels": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "array",
            "maxItems": 8192,
            "items": { "type": "number" }
          }
        },
        "inputBuses": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/audioBusBlock" }
        },
        "transport": { "$ref": "#/$defs/hostTransportState" }
      }
    },
    "audioBusBlock": {
      "type": "object",
      "required": ["index", "channels"],
      "additionalProperties": true,
      "properties": {
        "index": { "type": "integer", "minimum": 0, "maximum": 31 },
        "channels": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "array",
            "maxItems": 8192,
            "items": { "type": "number" }
          }
        }
      }
    },
    "hostTransportState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "playing": { "type": "boolean" },
        "recording": { "type": "boolean" },
        "loopActive": { "type": "boolean" },
        "tempo": { "type": "number", "minimum": 1, "maximum": 960 },
        "timeSignatureNumerator": { "type": "integer", "minimum": 1, "maximum": 64 },
        "timeSignatureDenominator": { "type": "integer", "enum": [1, 2, 4, 8, 16, 32, 64] },
        "projectTimeMusic": { "type": "number", "minimum": 0, "maximum": 1000000000 },
        "barPositionMusic": { "type": "number", "minimum": 0, "maximum": 1000000000 },
        "cycleStartMusic": { "type": "number", "minimum": 0, "maximum": 1000000000 },
        "cycleEndMusic": { "type": "number", "minimum": 0, "maximum": 1000000000 },
        "samplePosition": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
      }
    },
    "setParameterRequest": {
      "type": "object",
      "required": ["instanceId", "parameterId", "normalizedValue"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "setParameterDisplayValueRequest": {
      "type": "object",
      "required": ["instanceId", "parameterId", "displayValue"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "displayValue": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "setPresetRequest": {
      "type": "object",
      "required": ["instanceId", "presetId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "presetId": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "getVst3ProgramDataRequest": {
      "type": "object",
      "required": ["instanceId", "programListId", "programIndex"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "programListId": { "type": "integer", "minimum": -2147483648, "maximum": 2147483647 },
        "programIndex": { "type": "integer", "minimum": 0, "maximum": 255 }
      }
    },
    "setVst3ProgramDataRequest": {
      "type": "object",
      "required": ["instanceId", "programData"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "programData": { "type": "string", "minLength": 1, "maxLength": 1048576 }
      }
    },
    "parameterAutomationEvent": {
      "type": "object",
      "required": ["parameterId", "normalizedValue"],
      "additionalProperties": true,
      "properties": {
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 },
        "time": { "type": "integer", "minimum": 0, "maximum": 8191 }
      }
    },
    "parameterAutomationPoint": {
      "type": "object",
      "required": ["time", "normalizedValue"],
      "additionalProperties": true,
      "properties": {
        "time": { "type": "integer", "minimum": 0, "maximum": 8191 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "automationLanePoint": {
      "type": "object",
      "required": ["samplePosition", "normalizedValue"],
      "additionalProperties": true,
      "properties": {
        "samplePosition": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "setParameterEventsRequest": {
      "type": "object",
      "required": ["instanceId", "events"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "events": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/parameterAutomationEvent" }
        }
      }
    },
    "setParameterCurveRequest": {
      "type": "object",
      "required": ["instanceId", "parameterId", "points"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "interpolation": { "type": "string", "enum": ["linear", "step"] },
        "points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": { "$ref": "#/$defs/parameterAutomationPoint" }
        }
      }
    },
    "setAutomationLaneRequest": {
      "type": "object",
      "required": ["instanceId", "parameterId", "points"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/automationLanePoint" }
        }
      }
    },
    "clearAutomationLaneRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "getStateRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 }
      }
    },
    "setStateRequest": {
      "type": "object",
      "required": ["instanceId", "state"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "minLength": 1, "maxLength": 1048576 }
      }
    },
    "sendMidiEventsRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "events": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "./midi-event.schema.json#/$defs/midiEvent" }
        }
      }
    },
    "getLatencyRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "transportLatencySamples": { "type": "integer", "minimum": 0, "maximum": 1048576 }
      }
    },
    "getTailTimeRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 }
      }
    },
    "getLayoutRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 }
      }
    },
    "openEditorRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["generic", "native"] }
      }
    },
    "closeEditorRequest": {
      "type": "object",
      "required": ["editorId"],
      "additionalProperties": true,
      "properties": {
        "editorId": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "createFileGrantRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "purpose": { "type": "string", "enum": ["preset", "sample", "cache", "license", "state", "other"] },
        "access": { "type": "string", "enum": ["read", "write", "readWrite"] },
        "kind": { "type": "string", "enum": ["file", "directory"] }
      }
    },
    "revokeFileGrantRequest": {
      "type": "object",
      "required": ["grantId"],
      "additionalProperties": true,
      "properties": {
        "grantId": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "attachFileGrantRequest": {
      "type": "object",
      "required": ["instanceId", "grantId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "grantId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "purpose": { "type": "string", "enum": ["preset", "sample", "cache", "license", "state", "other"] },
        "access": { "type": "string", "enum": ["read", "write", "readWrite"] },
        "kind": { "type": "string", "enum": ["file", "directory"] }
      }
    },
    "listInstanceFileGrantsRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "detachFileGrantRequest": {
      "type": "object",
      "required": ["instanceId", "grantId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "grantId": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "useFileGrantRequest": {
      "type": "object",
      "required": ["instanceId", "grantId", "operation"],
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "properties": {
              "operation": { "const": "other" }
            },
            "required": ["operation"]
          },
          "then": { "required": ["purpose", "access", "kind"] }
        }
      ],
      "properties": {
        "instanceId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "grantId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "operation": {
          "type": "string",
          "enum": ["loadPreset", "loadSample", "openCacheDirectory", "loadLicense", "restoreState", "saveStateDirectory", "other"]
        },
        "purpose": { "type": "string", "enum": ["preset", "sample", "cache", "license", "state", "other"] },
        "access": { "type": "string", "enum": ["read", "write", "readWrite"] },
        "kind": { "type": "string", "enum": ["file", "directory"] }
      }
    }
  }
}
