{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soundbridge.dev/schema/protocol.schema.json",
  "title": "SoundBridge Protocol",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/requestEnvelope" },
    { "$ref": "#/$defs/responseEnvelope" },
    { "$ref": "#/$defs/eventEnvelope" }
  ],
  "$defs": {
    "command": {
      "type": "string",
      "enum": [
        "hello",
        "pair",
        "scanPlugins",
        "listPlugins",
        "createInstance",
        "destroyInstance",
        "getParameters",
        "setParameter",
        "setParameterDisplayValue",
        "setPreset",
        "getVst3ProgramData",
        "setVst3ProgramData",
        "setParameterEvents",
        "setParameterCurve",
        "setAutomationLane",
        "clearAutomationLane",
        "getState",
        "setState",
        "processAudioBlock",
        "sendMidiEvents",
        "getLatency",
        "getTailTime",
        "getLayout",
        "openEditor",
        "closeEditor",
        "createFileGrant",
        "listFileGrants",
        "revokeFileGrant",
        "attachFileGrant",
        "listInstanceFileGrants",
        "detachFileGrant",
        "useFileGrant",
        "heartbeat"
      ]
    },
    "pluginFormat": { "type": "string", "enum": ["vst3", "au", "lv2", "mock", "unknown"] },
    "pluginFormatCapability": { "$ref": "./defs/hello-response.schema.json#/$defs/pluginFormatCapability" },
    "helloResponse": { "$ref": "./defs/hello-response.schema.json#/$defs/helloResponse" },
    "requestEnvelope": { "$ref": "./defs/request-envelope.schema.json#/$defs/requestEnvelope" },
    "responseEnvelope": {
      "type": "object",
      "required": ["type", "id", "ok"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "response" },
        "id": { "type": "string", "minLength": 1 },
        "ok": { "type": "boolean" },
        "payload": {  },
        "error": { "$ref": "#/$defs/error" }
      }
    },
    "eventEnvelope": {
      "type": "object",
      "required": ["type", "event", "payload"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "event" },
        "event": { "type": "string", "minLength": 1 },
        "payload": {  }
      }
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": true,
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": {  }
      }
    },
    "pluginParameter": { "$ref": "./defs/plugin-metadata.schema.json#/$defs/pluginParameter" },
    "pluginVst3Unit": { "$ref": "./defs/plugin-metadata.schema.json#/$defs/pluginVst3Unit" },
    "pluginVst3MidiMapping": { "$ref": "./defs/plugin-metadata.schema.json#/$defs/pluginVst3MidiMapping" },
    "pluginProgram": { "$ref": "./defs/plugin-metadata.schema.json#/$defs/pluginProgram" },
    "pluginProgramList": { "$ref": "./defs/plugin-metadata.schema.json#/$defs/pluginProgramList" },
    "pluginVst3NoteExpression": { "$ref": "./defs/plugin-metadata.schema.json#/$defs/pluginVst3NoteExpression" },
    "pluginMetadata": { "$ref": "./defs/plugin-metadata.schema.json#/$defs/pluginMetadata" },
    "pluginClassMetadata": { "$ref": "./defs/plugin-metadata.schema.json#/$defs/pluginClassMetadata" },
    "pluginEditorKind": { "$ref": "./defs/plugin-metadata.schema.json#/$defs/pluginEditorKind" },
    "pluginLayout": { "$ref": "./defs/plugin-metadata.schema.json#/$defs/pluginLayout" },
    "pluginBusLayout": { "$ref": "./defs/plugin-metadata.schema.json#/$defs/pluginBusLayout" },
    "pluginPreset": { "$ref": "./defs/plugin-metadata.schema.json#/$defs/pluginPreset" },
    "vst3EventBusIndex": { "$ref": "./defs/midi-event.schema.json#/$defs/vst3EventBusIndex" },
    "midiEvent": { "$ref": "./defs/midi-event.schema.json#/$defs/midiEvent" },
    "parameterAutomationEvent": {
      "type": "object",
      "required": ["parameterId", "normalizedValue"],
      "additionalProperties": true,
      "properties": {
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 },
        "time": { "type": "integer", "minimum": 0, "maximum": 8191 }
      }
    },
    "parameterAutomationPoint": {
      "type": "object",
      "required": ["time", "normalizedValue"],
      "additionalProperties": true,
      "properties": {
        "time": { "type": "integer", "minimum": 0, "maximum": 8191 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "automationLanePoint": {
      "type": "object",
      "required": ["samplePosition", "normalizedValue"],
      "additionalProperties": true,
      "properties": {
        "samplePosition": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "pairRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "origin": { "type": "string" },
        "pairingToken": { "type": "string" }
      }
    },
    "createInstanceRequest": {
      "type": "object",
      "required": ["pluginId"],
      "additionalProperties": true,
      "properties": {
        "pluginId": { "type": "string", "minLength": 1 },
        "format": { "$ref": "#/$defs/pluginFormat" },
        "sampleRate": { "type": "number", "minimum": 8000, "maximum": 384000 },
        "maxBlockSize": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "inputChannels": { "type": "integer", "minimum": 0, "maximum": 32 },
        "outputChannels": { "type": "integer", "minimum": 1, "maximum": 32 }
      }
    },
    "processAudioBlockRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "blockId": { "type": "number" },
        "timestamp": { "type": "number" },
        "renderTimeoutMs": { "type": "number", "minimum": 0, "maximum": 60000 },
        "frames": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "sampleRate": { "type": "number", "minimum": 8000, "maximum": 384000 },
        "channels": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "array",
            "maxItems": 8192,
            "items": { "type": "number" }
          }
        },
        "inputBuses": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/audioBusBlock" }
        },
        "transport": { "$ref": "#/$defs/hostTransportState" }
      }
    },
    "audioBusBlock": {
      "type": "object",
      "required": ["index", "channels"],
      "additionalProperties": true,
      "properties": {
        "index": { "type": "integer", "minimum": 0, "maximum": 31 },
        "channels": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "array",
            "maxItems": 8192,
            "items": { "type": "number" }
          }
        }
      }
    },
    "hostTransportState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "playing": { "type": "boolean" },
        "recording": { "type": "boolean" },
        "loopActive": { "type": "boolean" },
        "tempo": { "type": "number", "minimum": 1, "maximum": 960 },
        "timeSignatureNumerator": { "type": "integer", "minimum": 1, "maximum": 64 },
        "timeSignatureDenominator": { "type": "integer", "enum": [1, 2, 4, 8, 16, 32, 64] },
        "projectTimeMusic": { "type": "number", "minimum": 0, "maximum": 1000000000 },
        "barPositionMusic": { "type": "number", "minimum": 0, "maximum": 1000000000 },
        "cycleStartMusic": { "type": "number", "minimum": 0, "maximum": 1000000000 },
        "cycleEndMusic": { "type": "number", "minimum": 0, "maximum": 1000000000 },
        "samplePosition": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
      }
    },
    "setParameterRequest": {
      "type": "object",
      "required": ["instanceId", "parameterId", "normalizedValue"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "setParameterDisplayValueRequest": {
      "type": "object",
      "required": ["instanceId", "parameterId", "displayValue"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "displayValue": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "setPresetRequest": {
      "type": "object",
      "required": ["instanceId", "presetId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "presetId": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "getVst3ProgramDataRequest": {
      "type": "object",
      "required": ["instanceId", "programListId", "programIndex"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "programListId": { "type": "integer", "minimum": -2147483648, "maximum": 2147483647, "not": { "const": -1 } },
        "programIndex": { "type": "integer", "minimum": 0, "maximum": 255 }
      }
    },
    "setVst3ProgramDataRequest": {
      "type": "object",
      "required": ["instanceId", "programData"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "programData": { "type": "string", "minLength": 1, "maxLength": 1048576 }
      }
    },
    "setParameterEventsRequest": {
      "type": "object",
      "required": ["instanceId", "events"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "events": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/parameterAutomationEvent" }
        }
      }
    },
    "setParameterCurveRequest": {
      "type": "object",
      "required": ["instanceId", "parameterId", "points"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "interpolation": { "type": "string", "enum": ["linear", "step"] },
        "points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": { "$ref": "#/$defs/parameterAutomationPoint" }
        }
      }
    },
    "setAutomationLaneRequest": {
      "type": "object",
      "required": ["instanceId", "parameterId", "points"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/automationLanePoint" }
        }
      }
    },
    "clearAutomationLaneRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "getStateRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 }
      }
    },
    "setStateRequest": {
      "type": "object",
      "required": ["instanceId", "state"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "minLength": 1, "maxLength": 1048576 }
      }
    },
    "sendMidiEventsRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "events": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/midiEvent" }
        }
      }
    },
    "getLatencyRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "transportLatencySamples": { "type": "integer", "minimum": 0, "maximum": 1048576 }
      }
    },
    "getTailTimeRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 }
      }
    },
    "getLayoutRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 }
      }
    },
    "openEditorRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["generic", "native"] }
      }
    },
    "closeEditorRequest": {
      "type": "object",
      "required": ["editorId"],
      "additionalProperties": true,
      "properties": {
        "editorId": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "fileGrantOperation": {
      "type": "string",
      "enum": ["loadPreset", "loadSample", "openCacheDirectory", "loadLicense", "restoreState", "saveStateDirectory", "other"]
    },
    "createFileGrantRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "purpose": { "type": "string", "enum": ["preset", "sample", "cache", "license", "state", "other"] },
        "access": { "type": "string", "enum": ["read", "write", "readWrite"] },
        "kind": { "type": "string", "enum": ["file", "directory"] }
      }
    },
    "revokeFileGrantRequest": {
      "type": "object",
      "required": ["grantId"],
      "additionalProperties": true,
      "properties": {
        "grantId": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "attachFileGrantRequest": {
      "type": "object",
      "required": ["instanceId", "grantId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "grantId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "purpose": { "type": "string", "enum": ["preset", "sample", "cache", "license", "state", "other"] },
        "access": { "type": "string", "enum": ["read", "write", "readWrite"] },
        "kind": { "type": "string", "enum": ["file", "directory"] }
      }
    },
    "listInstanceFileGrantsRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "detachFileGrantRequest": {
      "type": "object",
      "required": ["instanceId", "grantId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "grantId": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "useFileGrantRequest": {
      "type": "object",
      "required": ["instanceId", "grantId", "operation"],
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "properties": {
              "operation": { "const": "other" }
            },
            "required": ["operation"]
          },
          "then": { "required": ["purpose", "access", "kind"] }
        }
      ],
      "properties": {
        "instanceId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "grantId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "operation": {
          "type": "string",
          "enum": ["loadPreset", "loadSample", "openCacheDirectory", "loadLicense", "restoreState", "saveStateDirectory", "other"]
        },
        "purpose": { "type": "string", "enum": ["preset", "sample", "cache", "license", "state", "other"] },
        "access": { "type": "string", "enum": ["read", "write", "readWrite"] },
        "kind": { "type": "string", "enum": ["file", "directory"] }
      }
    }
  }
}
