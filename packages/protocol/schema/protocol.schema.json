{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soundbridge.dev/schema/protocol.schema.json",
  "title": "SoundBridge Protocol",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/requestEnvelope" },
    { "$ref": "#/$defs/responseEnvelope" },
    { "$ref": "#/$defs/eventEnvelope" }
  ],
  "$defs": {
    "command": {
      "type": "string",
      "enum": [
        "hello",
        "pair",
        "scanPlugins",
        "listPlugins",
        "createInstance",
        "destroyInstance",
        "getParameters",
        "setParameter",
        "setParameterEvents",
        "setParameterCurve",
        "getState",
        "setState",
        "processAudioBlock",
        "sendMidiEvents",
        "getLatency",
        "getTailTime",
        "getLayout",
        "openEditor",
        "closeEditor",
        "heartbeat"
      ]
    },
    "pluginFormat": {
      "type": "string",
      "enum": ["vst3", "au", "lv2", "mock", "unknown"]
    },
    "pluginFormatCapability": {
      "type": "object",
      "required": ["scan", "host"],
      "additionalProperties": true,
      "properties": {
        "scan": { "type": "boolean" },
        "host": { "type": "boolean" },
        "exampleHost": { "type": "boolean" },
        "mockExamples": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "helloResponse": {
      "type": "object",
      "required": ["name", "protocolVersion", "pairingRequired", "transports", "capabilities"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "protocolVersion": { "type": "string" },
        "pairingRequired": { "type": "boolean" },
        "transports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "url"],
            "additionalProperties": true,
            "properties": {
              "kind": { "type": "string" },
              "url": { "type": "string" },
              "audioEncoding": { "type": "string" }
            }
          }
        },
        "capabilities": {
          "type": "object",
          "required": ["pluginFormats"],
          "additionalProperties": true,
          "properties": {
            "pluginFormats": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/pluginFormatCapability" },
              "properties": {
                "vst3": { "$ref": "#/$defs/pluginFormatCapability" },
                "au": { "$ref": "#/$defs/pluginFormatCapability" },
                "lv2": { "$ref": "#/$defs/pluginFormatCapability" },
                "mock": { "$ref": "#/$defs/pluginFormatCapability" },
                "unknown": { "$ref": "#/$defs/pluginFormatCapability" }
              }
            },
            "security": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "originAllowlist": { "type": "boolean" },
                "sessionBoundToConnection": { "type": "boolean" },
                "sessionBoundToOrigin": { "type": "boolean" },
                "instanceOwnership": { "type": "boolean" },
                "cleanupOnDisconnect": { "type": "boolean" },
                "maxInstancesPerSession": { "type": "number" },
                "maxTotalInstances": { "type": "number" },
                "maxEditorsPerSession": { "type": "number" },
                "maxTotalEditors": { "type": "number" },
                "maxEditorSessionTtlMs": { "type": "number" },
                "maxParameterEventsPerRequest": { "type": "number" },
                "maxAutomationCurvePoints": { "type": "number" },
                "maxTransportTempoBpm": { "type": "number" },
                "maxTransportPositionMusic": { "type": "number" },
                "maxTransportSamplePosition": { "type": "number" }
              }
            },
            "automation": { "type": "boolean" },
            "transport": { "type": "boolean" },
            "genericEditor": { "type": "boolean" },
            "nativeEditor": { "type": "boolean" }
          }
        }
      }
    },
    "requestEnvelope": {
      "type": "object",
      "required": ["type", "id", "command", "payload"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "request" },
        "id": { "type": "string", "minLength": 1 },
        "command": { "$ref": "#/$defs/command" },
        "payload": { "type": "object" },
        "sessionToken": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "command": { "const": "pair" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/pairRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "createInstance" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/createInstanceRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "processAudioBlock" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/processAudioBlockRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "setParameter" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/setParameterRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "setParameterEvents" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/setParameterEventsRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "setParameterCurve" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/setParameterCurveRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "getState" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/getStateRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "setState" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/setStateRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "sendMidiEvents" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/sendMidiEventsRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "getLatency" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/getLatencyRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "getTailTime" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/getTailTimeRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "getLayout" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/getLayoutRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "openEditor" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/openEditorRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "closeEditor" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/closeEditorRequest" } } }
        }
      ]
    },
    "responseEnvelope": {
      "type": "object",
      "required": ["type", "id", "ok"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "response" },
        "id": { "type": "string", "minLength": 1 },
        "ok": { "type": "boolean" },
        "payload": {},
        "error": { "$ref": "#/$defs/error" }
      }
    },
    "eventEnvelope": {
      "type": "object",
      "required": ["type", "event", "payload"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "event" },
        "event": { "type": "string", "minLength": 1 },
        "payload": {}
      }
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": true,
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": {}
      }
    },
    "pluginParameter": {
      "type": "object",
      "required": ["id", "name", "normalizedValue", "defaultNormalizedValue", "automatable"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 64 },
        "name": { "type": "string", "maxLength": 160 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 },
        "defaultNormalizedValue": { "type": "number", "minimum": 0, "maximum": 1 },
        "unit": { "type": "string", "maxLength": 64 },
        "minPlain": { "type": "number" },
        "maxPlain": { "type": "number" },
        "plainValue": { "type": "number" },
        "automatable": { "type": "boolean" },
        "stepCount": { "type": "integer", "minimum": 0, "maximum": 1000000 },
        "readOnly": { "type": "boolean" },
        "programChange": { "type": "boolean" },
        "programList": { "$ref": "#/$defs/pluginProgramList" }
      }
    },
    "pluginProgram": {
      "type": "object",
      "required": ["index", "name", "normalizedValue"],
      "additionalProperties": false,
      "properties": {
        "index": { "type": "integer", "minimum": 0, "maximum": 255 },
        "name": { "type": "string", "maxLength": 160 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "pluginProgramList": {
      "type": "object",
      "required": ["id", "name", "programs"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "minimum": -2147483648, "maximum": 2147483647 },
        "name": { "type": "string", "maxLength": 160 },
        "programs": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/pluginProgram" }
        }
      }
    },
    "pluginMetadata": {
      "type": "object",
      "required": ["pluginId", "format", "name", "vendor", "category", "kind", "inputs", "outputs", "parameters"],
      "additionalProperties": true,
      "properties": {
        "pluginId": { "type": "string" },
        "format": { "$ref": "#/$defs/pluginFormat" },
        "name": { "type": "string" },
        "vendor": { "type": "string" },
        "category": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["effect", "instrument", "midi-effect", "unknown"]
        },
        "source": {
          "type": "string",
          "enum": ["scan", "example-bundle", "builtin-example", "mock", "unknown"]
        },
        "hostable": { "type": "boolean" },
        "hostUnavailableReason": { "type": "string" },
        "inputs": { "type": "integer", "minimum": 0 },
        "outputs": { "type": "integer", "minimum": 0 },
        "metadata": { "$ref": "#/$defs/pluginClassMetadata" },
        "tailSamples": { "type": "integer", "minimum": 0, "maximum": 1048576 },
        "infiniteTail": { "type": "boolean" },
        "parameters": {
          "type": "array",
          "maxItems": 1024,
          "items": { "$ref": "#/$defs/pluginParameter" }
        },
        "presets": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/pluginPreset" }
        }
      }
    },
    "pluginClassMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stableId": { "type": "string", "maxLength": 256 },
        "bundleIdentifier": { "type": "string", "maxLength": 256 },
        "version": { "type": "string", "maxLength": 80 },
        "componentType": { "type": "string", "maxLength": 16 },
        "componentSubType": { "type": "string", "maxLength": 16 },
        "componentManufacturer": { "type": "string", "maxLength": 16 },
        "lv2Uri": { "type": "string", "maxLength": 256 }
      }
    },
    "pluginLayout": {
      "type": "object",
      "required": [
        "requestedInputChannels",
        "requestedOutputChannels",
        "inputChannels",
        "outputChannels",
        "inputBuses",
        "outputBuses",
        "inputBusLayouts",
        "outputBusLayouts",
        "sampleRate",
        "maxBlockSize"
      ],
      "additionalProperties": true,
      "properties": {
        "requestedInputChannels": { "type": "integer", "minimum": 0, "maximum": 32 },
        "requestedOutputChannels": { "type": "integer", "minimum": 1, "maximum": 32 },
        "inputChannels": { "type": "integer", "minimum": 0, "maximum": 32 },
        "outputChannels": { "type": "integer", "minimum": 1, "maximum": 32 },
        "inputBuses": { "type": "integer", "minimum": 0, "maximum": 32 },
        "outputBuses": { "type": "integer", "minimum": 1, "maximum": 32 },
        "inputBusLayouts": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/pluginBusLayout" }
        },
        "outputBusLayouts": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/pluginBusLayout" }
        },
        "sampleRate": { "type": "number", "minimum": 8000, "maximum": 384000 },
        "maxBlockSize": { "type": "integer", "minimum": 1, "maximum": 8192 }
      }
    },
    "pluginBusLayout": {
      "type": "object",
      "required": ["index", "direction", "mediaType", "name", "type", "channels", "active"],
      "additionalProperties": true,
      "properties": {
        "index": { "type": "integer", "minimum": 0, "maximum": 31 },
        "direction": { "type": "string", "enum": ["input", "output"] },
        "mediaType": { "type": "string", "enum": ["audio"] },
        "name": { "type": "string", "maxLength": 160 },
        "type": { "type": "string", "enum": ["main", "aux", "unknown"] },
        "channels": { "type": "integer", "minimum": 0, "maximum": 32 },
        "active": { "type": "boolean" }
      }
    },
    "pluginPreset": {
      "type": "object",
      "required": ["id", "name", "parameters"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 64 },
        "name": { "type": "string", "maxLength": 160 },
        "parameters": {
          "type": "object",
          "maxProperties": 1024,
          "propertyNames": { "type": "string", "minLength": 1, "maxLength": 64 },
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "midiEvent": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "note"],
          "additionalProperties": true,
          "properties": {
            "type": { "const": "noteOn" },
            "note": { "type": "integer", "minimum": 0, "maximum": 127 },
            "velocity": { "type": "number", "minimum": 0, "maximum": 1 },
            "time": { "type": "integer", "minimum": 0, "maximum": 8191 },
            "channel": { "type": "integer", "minimum": 0, "maximum": 15 }
          }
        },
        {
          "type": "object",
          "required": ["type", "note"],
          "additionalProperties": true,
          "properties": {
            "type": { "const": "noteOff" },
            "note": { "type": "integer", "minimum": 0, "maximum": 127 },
            "velocity": { "type": "number", "minimum": 0, "maximum": 1 },
            "time": { "type": "integer", "minimum": 0, "maximum": 8191 },
            "channel": { "type": "integer", "minimum": 0, "maximum": 15 }
          }
        },
        {
          "type": "object",
          "required": ["type", "controller", "value"],
          "additionalProperties": true,
          "properties": {
            "type": { "const": "controlChange" },
            "controller": { "type": "integer", "minimum": 0, "maximum": 127 },
            "value": { "type": "number", "minimum": 0, "maximum": 1 },
            "time": { "type": "integer", "minimum": 0, "maximum": 8191 },
            "channel": { "type": "integer", "minimum": 0, "maximum": 15 }
          }
        },
        {
          "type": "object",
          "required": ["type", "value"],
          "additionalProperties": true,
          "properties": {
            "type": { "const": "pitchBend" },
            "value": { "type": "number", "minimum": -1, "maximum": 1 },
            "time": { "type": "integer", "minimum": 0, "maximum": 8191 },
            "channel": { "type": "integer", "minimum": 0, "maximum": 15 }
          }
        },
        {
          "type": "object",
          "required": ["type", "pressure"],
          "additionalProperties": true,
          "properties": {
            "type": { "const": "channelPressure" },
            "pressure": { "type": "number", "minimum": 0, "maximum": 1 },
            "time": { "type": "integer", "minimum": 0, "maximum": 8191 },
            "channel": { "type": "integer", "minimum": 0, "maximum": 15 }
          }
        },
        {
          "type": "object",
          "required": ["type", "note", "pressure"],
          "additionalProperties": true,
          "properties": {
            "type": { "const": "polyPressure" },
            "note": { "type": "integer", "minimum": 0, "maximum": 127 },
            "pressure": { "type": "number", "minimum": 0, "maximum": 1 },
            "time": { "type": "integer", "minimum": 0, "maximum": 8191 },
            "channel": { "type": "integer", "minimum": 0, "maximum": 15 }
          }
        },
        {
          "type": "object",
          "required": ["type", "program"],
          "additionalProperties": true,
          "properties": {
            "type": { "const": "programChange" },
            "program": { "type": "integer", "minimum": 0, "maximum": 127 },
            "time": { "type": "integer", "minimum": 0, "maximum": 8191 },
            "channel": { "type": "integer", "minimum": 0, "maximum": 15 }
          }
        }
      ]
    },
    "parameterAutomationEvent": {
      "type": "object",
      "required": ["parameterId", "normalizedValue"],
      "additionalProperties": true,
      "properties": {
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 },
        "time": { "type": "integer", "minimum": 0, "maximum": 8191 }
      }
    },
    "parameterAutomationPoint": {
      "type": "object",
      "required": ["time", "normalizedValue"],
      "additionalProperties": true,
      "properties": {
        "time": { "type": "integer", "minimum": 0, "maximum": 8191 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "pairRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "origin": { "type": "string" },
        "pairingToken": { "type": "string" }
      }
    },
    "createInstanceRequest": {
      "type": "object",
      "required": ["pluginId"],
      "additionalProperties": true,
      "properties": {
        "pluginId": { "type": "string", "minLength": 1 },
        "format": { "$ref": "#/$defs/pluginFormat" },
        "sampleRate": { "type": "number", "minimum": 8000, "maximum": 384000 },
        "maxBlockSize": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "inputChannels": { "type": "integer", "minimum": 0, "maximum": 32 },
        "outputChannels": { "type": "integer", "minimum": 1, "maximum": 32 }
      }
    },
    "processAudioBlockRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "blockId": { "type": "number" },
        "timestamp": { "type": "number" },
        "frames": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "sampleRate": { "type": "number", "minimum": 8000, "maximum": 384000 },
        "channels": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "array",
            "maxItems": 8192,
            "items": { "type": "number" }
          }
        },
        "inputBuses": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/audioBusBlock" }
        },
        "transport": { "$ref": "#/$defs/hostTransportState" }
      }
    },
    "audioBusBlock": {
      "type": "object",
      "required": ["index", "channels"],
      "additionalProperties": true,
      "properties": {
        "index": { "type": "integer", "minimum": 0, "maximum": 31 },
        "channels": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "array",
            "maxItems": 8192,
            "items": { "type": "number" }
          }
        }
      }
    },
    "hostTransportState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "playing": { "type": "boolean" },
        "recording": { "type": "boolean" },
        "loopActive": { "type": "boolean" },
        "tempo": { "type": "number", "minimum": 1, "maximum": 960 },
        "timeSignatureNumerator": { "type": "integer", "minimum": 1, "maximum": 64 },
        "timeSignatureDenominator": { "type": "integer", "enum": [1, 2, 4, 8, 16, 32, 64] },
        "projectTimeMusic": { "type": "number", "minimum": 0, "maximum": 1000000000 },
        "barPositionMusic": { "type": "number", "minimum": 0, "maximum": 1000000000 },
        "cycleStartMusic": { "type": "number", "minimum": 0, "maximum": 1000000000 },
        "cycleEndMusic": { "type": "number", "minimum": 0, "maximum": 1000000000 },
        "samplePosition": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
      }
    },
    "setParameterRequest": {
      "type": "object",
      "required": ["instanceId", "parameterId", "normalizedValue"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "setParameterEventsRequest": {
      "type": "object",
      "required": ["instanceId", "events"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "events": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/parameterAutomationEvent" }
        }
      }
    },
    "setParameterCurveRequest": {
      "type": "object",
      "required": ["instanceId", "parameterId", "points"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "interpolation": { "type": "string", "enum": ["linear", "step"] },
        "points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": { "$ref": "#/$defs/parameterAutomationPoint" }
        }
      }
    },
    "getStateRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 }
      }
    },
    "setStateRequest": {
      "type": "object",
      "required": ["instanceId", "state"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "minLength": 1, "maxLength": 1048576 }
      }
    },
    "sendMidiEventsRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "events": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/midiEvent" }
        }
      }
    },
    "getLatencyRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "transportLatencySamples": { "type": "integer", "minimum": 0, "maximum": 1048576 }
      }
    },
    "getTailTimeRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 }
      }
    },
    "getLayoutRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 }
      }
    },
    "openEditorRequest": {
