{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soundbridge.dev/schema/protocol.schema.json",
  "title": "SoundBridge Protocol",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/requestEnvelope" },
    { "$ref": "#/$defs/responseEnvelope" },
    { "$ref": "#/$defs/eventEnvelope" }
  ],
  "$defs": {
    "command": {
      "type": "string",
      "enum": [
        "hello",
        "pair",
        "scanPlugins",
        "listPlugins",
        "createInstance",
        "destroyInstance",
        "getParameters",
        "setParameter",
        "getState",
        "setState",
        "processAudioBlock",
        "sendMidiEvents",
        "getLatency",
        "openEditor",
        "closeEditor",
        "heartbeat"
      ]
    },
    "pluginFormat": {
      "type": "string",
      "enum": ["vst3", "au", "lv2", "mock", "unknown"]
    },
    "pluginFormatCapability": {
      "type": "object",
      "required": ["scan", "host"],
      "additionalProperties": true,
      "properties": {
        "scan": { "type": "boolean" },
        "host": { "type": "boolean" },
        "exampleHost": { "type": "boolean" },
        "mockExamples": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "helloResponse": {
      "type": "object",
      "required": ["name", "protocolVersion", "pairingRequired", "transports", "capabilities"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "protocolVersion": { "type": "string" },
        "pairingRequired": { "type": "boolean" },
        "transports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "url"],
            "additionalProperties": true,
            "properties": {
              "kind": { "type": "string" },
              "url": { "type": "string" },
              "audioEncoding": { "type": "string" }
            }
          }
        },
        "capabilities": {
          "type": "object",
          "required": ["pluginFormats"],
          "additionalProperties": true,
          "properties": {
            "pluginFormats": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/pluginFormatCapability" },
              "properties": {
                "vst3": { "$ref": "#/$defs/pluginFormatCapability" },
                "au": { "$ref": "#/$defs/pluginFormatCapability" },
                "lv2": { "$ref": "#/$defs/pluginFormatCapability" },
                "mock": { "$ref": "#/$defs/pluginFormatCapability" },
                "unknown": { "$ref": "#/$defs/pluginFormatCapability" }
              }
            },
            "security": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "originAllowlist": { "type": "boolean" },
                "sessionBoundToConnection": { "type": "boolean" },
                "sessionBoundToOrigin": { "type": "boolean" },
                "instanceOwnership": { "type": "boolean" },
                "cleanupOnDisconnect": { "type": "boolean" },
                "maxInstancesPerSession": { "type": "number" },
                "maxTotalInstances": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "requestEnvelope": {
      "type": "object",
      "required": ["type", "id", "command", "payload"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "request" },
        "id": { "type": "string", "minLength": 1 },
        "command": { "$ref": "#/$defs/command" },
        "payload": { "type": "object" },
        "sessionToken": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "command": { "const": "pair" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/pairRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "createInstance" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/createInstanceRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "processAudioBlock" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/processAudioBlockRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "setParameter" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/setParameterRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "getState" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/getStateRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "setState" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/setStateRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "sendMidiEvents" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/sendMidiEventsRequest" } } }
        },
        {
          "if": { "properties": { "command": { "const": "getLatency" } }, "required": ["command"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/getLatencyRequest" } } }
        }
      ]
    },
    "responseEnvelope": {
      "type": "object",
      "required": ["type", "id", "ok"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "response" },
        "id": { "type": "string", "minLength": 1 },
        "ok": { "type": "boolean" },
        "payload": {},
        "error": { "$ref": "#/$defs/error" }
      }
    },
    "eventEnvelope": {
      "type": "object",
      "required": ["type", "event", "payload"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "event" },
        "event": { "type": "string", "minLength": 1 },
        "payload": {}
      }
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": true,
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": {}
      }
    },
    "pluginParameter": {
      "type": "object",
      "required": ["id", "name", "normalizedValue", "defaultNormalizedValue", "automatable"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 64 },
        "name": { "type": "string", "maxLength": 160 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 },
        "defaultNormalizedValue": { "type": "number", "minimum": 0, "maximum": 1 },
        "unit": { "type": "string", "maxLength": 64 },
        "minPlain": { "type": "number" },
        "maxPlain": { "type": "number" },
        "plainValue": { "type": "number" },
        "automatable": { "type": "boolean" },
        "stepCount": { "type": "integer", "minimum": 0, "maximum": 1000000 },
        "readOnly": { "type": "boolean" }
      }
    },
    "pluginMetadata": {
      "type": "object",
      "required": ["pluginId", "format", "name", "vendor", "category", "kind", "inputs", "outputs", "parameters"],
      "additionalProperties": true,
      "properties": {
        "pluginId": { "type": "string" },
        "format": { "$ref": "#/$defs/pluginFormat" },
        "name": { "type": "string" },
        "vendor": { "type": "string" },
        "category": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["effect", "instrument", "midi-effect", "unknown"]
        },
        "source": {
          "type": "string",
          "enum": ["scan", "example-bundle", "builtin-example", "mock", "unknown"]
        },
        "hostable": { "type": "boolean" },
        "hostUnavailableReason": { "type": "string" },
        "inputs": { "type": "integer", "minimum": 0 },
        "outputs": { "type": "integer", "minimum": 0 },
        "parameters": {
          "type": "array",
          "maxItems": 1024,
          "items": { "$ref": "#/$defs/pluginParameter" }
        },
        "presets": {
          "type": "array",
          "items": { "$ref": "#/$defs/pluginPreset" }
        }
      }
    },
    "pluginPreset": {
      "type": "object",
      "required": ["id", "name", "parameters"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "midiEvent": {
      "type": "object",
      "required": ["type", "note"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["noteOn", "noteOff"]
        },
        "note": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127
        },
        "velocity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "time": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8191
        },
        "channel": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        }
      }
    },
    "pairRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "origin": { "type": "string" },
        "pairingToken": { "type": "string" }
      }
    },
    "createInstanceRequest": {
      "type": "object",
      "required": ["pluginId"],
      "additionalProperties": true,
      "properties": {
        "pluginId": { "type": "string", "minLength": 1 },
        "format": { "$ref": "#/$defs/pluginFormat" },
        "sampleRate": { "type": "number", "minimum": 8000, "maximum": 384000 },
        "maxBlockSize": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "inputChannels": { "type": "integer", "minimum": 0, "maximum": 32 },
        "outputChannels": { "type": "integer", "minimum": 1, "maximum": 32 }
      }
    },
    "processAudioBlockRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "blockId": { "type": "number" },
        "timestamp": { "type": "number" },
        "frames": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "sampleRate": { "type": "number", "minimum": 8000, "maximum": 384000 },
        "channels": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "array",
            "maxItems": 8192,
            "items": { "type": "number" }
          }
        }
      }
    },
    "setParameterRequest": {
      "type": "object",
      "required": ["instanceId", "parameterId", "normalizedValue"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "parameterId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "normalizedValue": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "getStateRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 }
      }
    },
    "setStateRequest": {
      "type": "object",
      "required": ["instanceId", "state"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "minLength": 1, "maxLength": 1048576 }
      }
    },
    "sendMidiEventsRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "events": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/midiEvent" }
        }
      }
    },
    "getLatencyRequest": {
      "type": "object",
      "required": ["instanceId"],
      "additionalProperties": true,
      "properties": {
        "instanceId": { "type": "string", "minLength": 1 },
        "transportLatencySamples": { "type": "integer", "minimum": 0, "maximum": 1048576 }
      }
    }
  }
}
