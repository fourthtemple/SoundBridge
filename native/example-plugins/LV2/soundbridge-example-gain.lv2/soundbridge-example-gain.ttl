@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix lv2: <http://lv2plug.in/ns/lv2core#> .

<urn:soundbridge:example:lv2-gain>
  a lv2:Plugin ;
  doap:name "SoundBridge Example LV2 Gain" ;
  lv2:port [
    a lv2:InputPort, lv2:ControlPort ;
    lv2:index 0 ;
    lv2:symbol "gain" ;
    lv2:name "Gain" ;
    lv2:default 1.0 ;
    lv2:minimum 0.0 ;
    lv2:maximum 2.0
  ], [
    a lv2:InputPort, lv2:AudioPort ;
    lv2:index 1 ;
    lv2:symbol "in_l" ;
    lv2:name "Input L"
  ], [
    a lv2:InputPort, lv2:AudioPort ;
    lv2:index 2 ;
    lv2:symbol "in_r" ;
    lv2:name "Input R"
  ], [
    a lv2:OutputPort, lv2:AudioPort ;
    lv2:index 3 ;
    lv2:symbol "out_l" ;
    lv2:name "Output L"
  ], [
    a lv2:OutputPort, lv2:AudioPort ;
    lv2:index 4 ;
    lv2:symbol "out_r" ;
    lv2:name "Output R"
  ] .
